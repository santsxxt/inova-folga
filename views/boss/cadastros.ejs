<!doctype html><html lang="pt-br"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Cadastros</title><link rel="stylesheet" href="/css/app.css"></head>
<body>
  <%- include('../partials/topo') %>
  <main>
    <h2 style="margin:0 0 12px;font-size:18px">Funcionários</h2>
    <form method="post" action="/cadastros" class="card" style="width:auto;max-width:760px;margin-bottom:16px;grid-template-columns:repeat(5,auto);align-items:end">
      <label>Nome<br><input name="nome" required></label>
      <label>Setor<br><select name="setorId"><option value="">—</option>
        <% setores.forEach(s => { %><option value="<%= s.id %>"><%= s.nome %></option><% }) %></select></label>
      <label>Cor<br><input name="cor" type="color" value="#7fb3ff"></label>
      <label>Aniversário<br><input name="aniversario" placeholder="DD/MM" style="width:90px"></label>
      <label>PIN<br><input name="pin" inputmode="numeric" placeholder="ex 1234" style="width:90px"></label>
      <button>Adicionar</button>
    </form>

    <div class="grid-wrap">
    <table class="tabela">
      <thead><tr><th>Nome</th><th>Setor</th><th>Cor</th><th>Aniv.</th><th>Ativo</th><th>PIN</th><th>Ações</th></tr></thead>
      <tbody>
        <% funcionarios.forEach(f => { %>
        <tr>
          <td><form method="post" action="/cadastros/<%= f.id %>/editar" id="ed<%= f.id %>" style="margin:0">
              <input name="nome" value="<%= f.nome %>" style="width:130px"></form></td>
          <td><select name="setorId" form="ed<%= f.id %>"><option value="">—</option>
              <% setores.forEach(s => { %><option value="<%= s.id %>" <%= f.setor_id == s.id ? 'selected' : '' %>><%= s.nome %></option><% }) %></select></td>
          <td><input type="color" name="cor" form="ed<%= f.id %>" value="<%= f.cor || '#cccccc' %>"></td>
          <td><input name="aniversario" form="ed<%= f.id %>" value="<%= f.aniversario || '' %>" style="width:64px"></td>
          <td><%= f.ativo ? 'sim' : 'não' %></td>
          <td><form method="post" action="/cadastros/<%= f.id %>/pin" style="display:flex;gap:4px;margin:0">
              <input name="pin" placeholder="novo PIN" style="width:84px"><button>OK</button></form></td>
          <td style="display:flex;gap:6px">
            <button form="ed<%= f.id %>">Salvar</button>
            <% if (f.ativo) { %>
              <form method="post" action="/cadastros/<%= f.id %>/desativar" style="margin:0"><button class="cinza">Desativar</button></form>
            <% } else { %>
              <form method="post" action="/cadastros/<%= f.id %>/reativar" style="margin:0"><button class="cinza">Reativar</button></form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  </main>
</body></html>
