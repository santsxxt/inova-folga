<!doctype html><html lang="pt-br"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Minha Escala</title><link rel="stylesheet" href="/css/app.css?v=4">
<style>
  .fhead{ display:flex; align-items:center; gap:12px; }
  .fhead .av{ width:46px;height:46px;border-radius:50%;background:conic-gradient(from 200deg,#ff7a88,#ff3b4e,#c8102e,#8f1020);
    display:flex;align-items:center;justify-content:center;font-weight:800;font-size:18px;box-shadow:0 0 0 2px rgba(255,255,255,.14);flex:0 0 auto; }
  .fhead .oi{ font-size:13px;color:var(--muted); } .fhead .nm{ font-size:21px;font-weight:800;letter-spacing:-.3px;line-height:1.1; }
  .hoje{ display:flex; align-items:center; gap:12px; padding:16px; margin-top:4px; }
  .hoje .ic{ width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex:0 0 auto; }
  .hoje small{ color:var(--muted);font-size:12px; } .hoje strong{ display:block;font-size:18px;font-weight:800;margin-top:2px; }
  .week{ padding:14px; } .week .wt{ font-size:11px;color:var(--muted);margin-bottom:9px;text-transform:uppercase;letter-spacing:.5px; }
  .wrow{ display:flex; gap:6px; }
  .wd{ flex:1; text-align:center; } .wd .d{ font-size:9px;color:var(--muted); } .wd .n{ font-size:12px;font-weight:700;margin:3px 0 5px; }
  .wd.hoje-col .n{ color:var(--vermelho); }
  .wd .x{ height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:11px;color:#fff;
    box-shadow:inset 0 1px 0 rgba(255,255,255,.25); } .wd .x.vazio{ background:rgba(255,255,255,.05);box-shadow:none; }
  .acoes-g{ display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-top:4px; }
  .acoes-g a{ text-decoration:none;color:#fff;border-radius:16px;padding:16px 8px;text-align:center;font-weight:700;font-size:13px;
    display:flex;flex-direction:column;align-items:center;gap:6px;transition:.15s;border:1px solid var(--borda); }
  .acoes-g a:hover{ transform:translateY(-2px); } .acoes-g a .e{ font-size:22px; }
  .a-fer{ background:linear-gradient(135deg,rgba(255,216,77,.22),rgba(255,216,77,.06)); }
  .a-fol{ background:linear-gradient(135deg,rgba(123,209,138,.22),rgba(123,209,138,.06)); }
  .a-tro{ background:linear-gradient(135deg,rgba(91,155,255,.22),rgba(91,155,255,.06)); }
  .vermais{ display:block;text-align:center;font-weight:700;color:var(--vermelho);text-decoration:none;padding:12px;
    border:1px solid var(--borda);border-radius:14px;background:var(--glass); }
  .mini{ display:flex; gap:10px; } .mini .card{ flex:1; padding:13px; } .mini small{ color:var(--muted);font-size:11px; } .mini strong{ display:block;font-size:15px;margin-top:3px; }
</style></head>
<body>
  <div class="appbar"><span class="marca">Inova Folga</span><a href="/app/logout">Sair</a></div>
  <main class="col">
    <% const ini = (hojeTurno && rotuloTurno[hojeTurno.turno]) ? rotuloTurno[hojeTurno.turno] : 'Sem turno marcado'; %>
    <div class="fhead">
      <div class="av"><%= (nome||'?').trim().charAt(0).toUpperCase() %></div>
      <div><div class="oi">Olá 👋</div><div class="nm"><%= nome %></div></div>
    </div>

    <div class="card hoje" style="<%= hojeTurno ? 'border-left:5px solid ' + (corPorTurno[hojeTurno.turno] || '#888') : '' %>">
      <div class="ic" style="background:<%= hojeTurno ? (corPorTurno[hojeTurno.turno] || 'rgba(255,255,255,.1)') : 'rgba(255,255,255,.1)' %>">📅</div>
      <div><small>Hoje · <%= hoje %></small><strong><%= ini %></strong></div>
    </div>

    <div class="card week">
      <div class="wt">Sua semana</div>
      <div class="wrow">
        <% semana.forEach(d => { const t = d.turno; %>
          <div class="wd <%= d.iso === hoje ? 'hoje-col' : '' %>">
            <div class="d"><%= d.semana %></div><div class="n"><%= d.dia %></div>
            <div class="x <%= t ? '' : 'vazio' %>" style="<%= t ? 'background:' + (corPorTurno[t] || '#888') : '' %>"
                 title="<%= t ? rotuloTurno[t] : '' %>"><%= t ? (rotuloTurno[t]||'').charAt(0).toUpperCase() : '' %></div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="mini">
      <div class="card"><small>Próxima folga</small><strong><%= proximaFolga ? proximaFolga.data : '—' %></strong></div>
      <div class="card"><small>Próximas férias</small><strong><%= proximasFerias ? proximasFerias.data : '—' %></strong></div>
    </div>

    <div class="acoes-g">
      <a class="a-fer" href="/app/pedido?tipo=ferias"><span class="e">🌴</span>Agendar férias</a>
      <a class="a-fol" href="/app/pedido?tipo=folga"><span class="e">😴</span>Pedir folga</a>
      <a class="a-tro" href="/app/pedido?tipo=troca"><span class="e">🔁</span>Trocar dia</a>
    </div>
    <a class="vermais" href="/app/meus-pedidos">Meus pedidos →</a>
  </main>
</body></html>
