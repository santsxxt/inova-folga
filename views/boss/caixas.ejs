<!doctype html><html lang="pt-br"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Escala de Caixas</title><link rel="stylesheet" href="/css/app.css?v=4"></head>
<body>
  <%- include('../partials/topo') %>
  <main>
    <div class="barra">
      <h2>Caixas / Entrega</h2>
      <form method="get"><input type="date" name="data" value="<%= data %>" onchange="this.form.submit()"></form>
    </div>

    <div class="grid-wrap" style="max-width:860px">
    <table class="tabela">
      <thead><tr><th>Posto</th>
        <% horarios.forEach(h => { %>
          <th>
            <%= h.horario %>
            <form method="post" action="/caixas/horario/<%= h.id %>/remover" style="display:inline;margin:0">
              <input type="hidden" name="data" value="<%= data %>">
              <button class="x" title="remover horário">×</button>
            </form>
          </th>
        <% }) %>
      </tr></thead>
      <tbody>
        <% postos.forEach(p => { %>
        <tr><td><strong><%= p %></strong></td>
          <% horarios.forEach(h => { const sel = mapa[p + '|' + h.horario]; %>
          <td><form method="post" action="/caixas" style="margin:0">
            <input type="hidden" name="data" value="<%= data %>">
            <input type="hidden" name="posto" value="<%= p %>">
            <input type="hidden" name="horario" value="<%= h.horario %>">
            <select name="funcionarioId" onchange="this.form.submit()">
              <option value="">—</option>
              <% funcionarios.forEach(f => { %><option value="<%= f.id %>" <%= sel == f.id ? 'selected' : '' %>><%= f.nome %></option><% }) %>
            </select>
          </form></td>
          <% }) %>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>

    <form method="post" action="/caixas/horario" class="card" style="width:auto;max-width:420px;margin-top:14px;grid-template-columns:1fr auto;align-items:end">
      <input type="hidden" name="data" value="<%= data %>">
      <label>Novo horário<br><input name="horario" placeholder="06:00-14:30" required></label>
      <button>Adicionar horário</button>
    </form>
  </main>
</body></html>
